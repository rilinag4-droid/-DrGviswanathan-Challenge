class Solution {
public:
    int findNthDigit(int n) {
        long long digit = 1;
        long long start = 1;
        long long count = 9;

        while (n > digit * count) {
            n -= digit * count;
            digit++;
            count *= 10;
            start *= 10;
        }

        start += (n - 1) / digit;

        string num = to_string(start);

        return num[(n - 1) % digit] - '0';
    }
};
